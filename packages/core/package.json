{
  "name": "@vankyle-hub/storage-core",
  "version": "0.2.4",
  "description": "Domain models, interfaces, and application services for vankyle-storage.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b tsconfig.json --force",
    "clean": "rimraf dist tsconfig.tsbuildinfo",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "license": "MPL-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Vankyle-Hub/storage-ts.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/Vankyle-Hub/storage-ts/issues"
  },
  "homepage": "https://github.com/Vankyle-Hub/storage-ts",
  "packageManager": "pnpm@10.28.2",
  "dependencies": {
    "@vankyle-hub/storage-shared": "workspace:*",
    "zod": "^4.3.6"
  },
  "publishConfig": {
    "access": "public"
  }
}
